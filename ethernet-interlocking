#include <UIPEthernet.h>
#include <PubSubClient.h>
#include <SPI.h>
#include <avr/wdt.h>

// ---------------- PIN DEFINITIONS ----------------
#define RELAY_PIN   7
#define LED_POWER   5
#define LED_MQTT    6
#define LED_RELAY   8

// ---------------- NETWORK ----------------
byte mac[] = {0xAC,0x0A,0xE7,0xFF,0xDC,0x06};

IPAddress mqttServer(192,168,8,109);
const int mqttPort = 1883;

// ---------------- STATIC IP ----------------
IPAddress staticIP(192,168,8,210);
IPAddress gateway(192,168,1,1);
IPAddress subnet(255,255,255,0);
IPAddress dnsServer(192,168,1,1);

// ---------------- TOPICS ----------------
const char pubTopic[] = "pub1/AC0AE7FFDC06/";
const char subTopic[] = "sub1/AC0AE7FFDC06/";

// ---------------- OBJECTS ----------------
EthernetClient ethClient;
PubSubClient client(ethClient);

// ---------------- VARIABLES ----------------
bool relayState = LOW;

unsigned long lastPublish = 0;
unsigned long lastRestart = 0;

unsigned long seqCounter = 0;

// =====================================================
// APPLY RELAY
// =====================================================
void applyRelay(bool state)
{
    relayState = state;

    digitalWrite(RELAY_PIN, state);
    digitalWrite(LED_RELAY, state);
}

// =====================================================
// PUBLISH STATUS
// =====================================================
void publishStatus()
{
    if(!client.connected())
        return;

    seqCounter++;

    char macStr[18];

    sprintf(
        macStr,
        "%02X:%02X:%02X:%02X:%02X:%02X",
        mac[0],
        mac[1],
        mac[2],
        mac[3],
        mac[4],
        mac[5]
    );

    int lockVal = relayState ? 1 : 0;

    char msg[120];

    sprintf(
        msg,
        "{\"data\":{\"mac\":\"%s\",\"status\":{\"lock1\":%d},\"seq\":%lu}}",
        macStr,
        lockVal,
        seqCounter
    );

    if(client.publish(pubTopic,msg))
    {
        digitalWrite(LED_MQTT,HIGH);
        delay(40);
        digitalWrite(LED_MQTT,LOW);
    }
}

// =====================================================
// MQTT CALLBACK
// =====================================================
void callback(char* topic, byte* payload, unsigned int length)
{
    char msg[64];

    memset(msg,0,sizeof(msg));

    if(length > sizeof(msg)-1)
    {
        length = sizeof(msg)-1;
    }

    memcpy(msg,payload,length);

    // -------- UNLOCK1 --------
    if(strstr(msg,"UNLOCK1") != NULL)
    {
        applyRelay(LOW);
        publishStatus();
        return;
    }

    // -------- LOCK1 --------
    if(strstr(msg,"LOCK1") != NULL)
    {
        applyRelay(HIGH);
        publishStatus();
        return;
    }
}

// =====================================================
// MQTT RECONNECT
// =====================================================
void reconnect()
{
    while(!client.connected())
    {
        if(client.connect("AC0AE7FFDC06/"))
        {
            client.subscribe(subTopic);

            digitalWrite(LED_RELAY,HIGH);
            delay(300);
            digitalWrite(LED_RELAY,LOW);

            publishStatus();
        }
        else
        {
            delay(2000);
        }
    }
}

// =====================================================
// SETUP
// =====================================================
void setup()
{
    wdt_enable(WDTO_8S);

    pinMode(10,OUTPUT);
    digitalWrite(10,HIGH);

    pinMode(RELAY_PIN,OUTPUT);
    pinMode(LED_POWER,OUTPUT);
    pinMode(LED_MQTT,OUTPUT);
    pinMode(LED_RELAY,OUTPUT);

    digitalWrite(LED_POWER,HIGH);

    applyRelay(LOW);

    Ethernet.begin(
        mac,
        staticIP,
        dnsServer,
        gateway,
        subnet
    );

    delay(2000);

    client.setServer(
        mqttServer,
        mqttPort
    );

    client.setCallback(callback);

    client.setBufferSize(256);

    lastRestart = millis();
}

// =====================================================
// LOOP
// =====================================================
void loop()
{
    wdt_reset();

    if(!client.connected())
    {
        reconnect();
    }

    client.loop();

    // publish every 2 sec
    if(millis()-lastPublish>=2000)
    {
        lastPublish=millis();

        publishStatus();
    }

    // restart every 1 hour
    if(millis()-lastRestart>=3600000UL)
    {
        wdt_enable(WDTO_15MS);

        while(1)
        {
        }
    }
}
