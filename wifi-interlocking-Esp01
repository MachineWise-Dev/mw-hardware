// ---------- MQTT SEND ----------
void sendMQTT()
{
  String mac = WiFi.macAddress();
mac.replace(":", "");

String ip = WiFi.localIP().toString();

String payload = "{";
payload += "\"data\":{";

payload += "\"qr\":\"" + lastQR + "\",";

payload += "\"mac\":\"" + mac + "\",";

payload += "\"status\":{";
payload += "\"lock1\":" + String(relayState);
payload += "},";

payload += "\"network\":{";
payload += "\"wlan0\":{";
payload += "\"ip\":\"" + ip + "\"";
payload += "}";
payload += "}";

payload += "}}";
  if (client.publish(pubTopic.c_str(), payload.c_str()))
{
  Serial.println("MQTT_SENT");
}
}

// ---------- MQTT CALLBACK ----------
void callback(char* topic, byte* payload, unsigned int length)
{
  mqttCmd = "";

  for (unsigned int i = 0; i < length; i++)
  {
    mqttCmd += (char)payload[i];
  }

  mqttCmd.trim();
}

// ---------- MQTT RECONNECT ----------
void reconnect()
{
  while (!client.connected())
  {
    if (client.connect("ESP01"))
    {
      client.subscribe(subTopic.c_str());
    }
    else
    {
      delay(1500);
    }
  }
}

// ---------- SETUP ----------
void setup()
{
  Serial.begin(9600);

  delay(1000);

  setup_wifi();

macID = WiFi.macAddress();
macID.replace(":", "");

pubTopic = "pub1/" + macID;
subTopic = "sub1/" + macID;

client.setServer(mqtt_server, 1883);
client.setCallback(callback);
}

// ---------- LOOP ----------
void loop()
{
  if (!client.connected())
  {
    reconnect();
  }

  client.loop();

  // ---------- MQTT COMMAND ----------
  if (mqttCmd.length() > 0)
  {
    if (mqttCmd == "LOCK1" || mqttCmd == "lock1")
    {
      relayState = 1;

      sendToArduino();

      sendMQTT();
    }
    else if (mqttCmd == "UNLOCK1" || mqttCmd == "unlock1")
    {
      relayState = 0;

      sendToArduino();

      sendMQTT();
    }

    mqttCmd = "";
  }

  // ---------- RECEIVE FROM ARDUINO ----------
  if (Serial.available())
  {
    String data = Serial.readStringUntil('\n');
    data.trim();

    if (data.startsWith("QR:"))
{
  lastQR = data.substring(3);

  // If relay is locked, unlock it
  if (relayState == 1)
  {
    relayState = 0;

    sendToArduino();   // Sends UNLOCK to Arduino

    // Immediately publish new relay state
    sendMQTT();
  }

  // Publish QR payload
  sendMQTT();

  httpCodeVal = callAPI(lastQR);

  if (httpCodeVal >= 200 && httpCodeVal < 300)
  {
    Serial.println("QR_OK");
    delay(50);
    Serial.println("QR_OK");
  }
  else
  {
    Serial.println("QR_NOT_OK");
    delay(50);
    Serial.println("QR_NOT_OK");
  }

  // Clear QR after processing
  lastQR = "";

  // Publish final state with empty QR
  sendMQTT();
}
  }

  // ---------- MQTT UPDATE ----------
  if (millis() - lastMQTT > 1000)
  {
    lastMQTT = millis();

    sendMQTT();
  }
}
